  "mcpServers": {
    "ibmi-mcp-server": {
      "command": "npx",
      "args": ["-y", "@ibm/ibmi-mcp-server@latest"],
      "env": {
        "NODE_OPTIONS": "--no-deprecation",
        "DB2i_HOST": "",
        "DB2i_USER": "",
        "DB2i_PASS": "",
        "DB2i_PORT": "8076",
        "MCP_TRANSPORT_TYPE": "stdio",
        "IBMI_ENABLE_EXECUTE_SQL": "true"
      }
    }
  }
