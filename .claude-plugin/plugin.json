    "./skills/ifs",
    "./skills/java",
    "./skills/journal",
    "./skills/librarian",
    "./skills/message-handling",
    "./skills/migrate-while-active",
    "./skills/mirror",
    "./skills/performance",
    "./skills/product",
    "./skills/ptf",
